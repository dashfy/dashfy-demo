{
  "name": "dashfy-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "dev:all": "concurrently \"pnpm dev:server\" \"pnpm dev\"",
    "dev:server": "dotenv -e .env -- tsx watch dashfy.server.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "tsx dashfy.server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@getdashfy/server": "^0.1.1",
    "@getdashfy/ui": "^0.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1"
  }
}
